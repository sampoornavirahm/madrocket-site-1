{
  "entities": {
    "SiteConfig": {
      "title": "Site Configuration",
      "description": "Global settings and content for the entire website",
      "type": "object",
      "properties": {
        "brand": { "type": "string", "description": "Agency name" },
        "hero": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "subtitle": { "type": "string" },
            "cta": { "type": "string" }
          },
          "required": ["title", "subtitle", "cta"]
        },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" },
              "icon": { "type": "string" }
            },
            "required": ["id", "title", "description"]
          }
        },
        "plans": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "price": { "type": "string" },
              "features": { "type": "array", "items": { "type": "string" } },
              "highlight": { "type": "boolean" }
            },
            "required": ["name", "price", "features"]
          }
        },
        "about": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "content": { "type": "string" }
          }
        },
        "contact": {
          "type": "object",
          "properties": {
            "email": { "type": "string" },
            "address": { "type": "string" }
          }
        },
        "clients": {
          "type": "array",
          "items": { "type": "string" }
        },
        "socialLinks": {
          "type": "object",
          "properties": {
            "instagram": { "type": "string" },
            "linkedin": { "type": "string" },
            "twitter": { "type": "string" },
            "facebook": { "type": "string" }
          }
        },
        "marketing": {
          "type": "object",
          "properties": {
            "googleAnalyticsId": { "type": "string" },
            "googleTagManagerId": { "type": "string" },
            "metaPixelId": { "type": "string" }
          }
        }
      },
      "required": ["brand", "hero", "services", "plans"]
    },
    "Enquiry": {
      "title": "Contact Enquiry",
      "description": "Data from the contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "plan": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "plan", "message", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User roles and organizational data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "sales", "lead"] },
        "status": { "type": "string", "enum": ["pending", "active", "denied"] },
        "team": { "type": "string" },
        "batch": { "type": "string" }
      },
      "required": ["uid", "email", "role", "status"]
    },
    "Lead": {
      "title": "Sales Lead",
      "description": "Tracking lead status for sales team",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string" },
        "team": { "type": "string" },
        "batch": { "type": "string" },
        "salesRepId": { "type": "string" },
        "salesRepName": { "type": "string" },
        "schoolName": { "type": "string" },
        "cityArea": { "type": "string" },
        "decisionMaker": { "type": "string" },
        "currentDigitalStatus": { "type": "string" },
        "contactNumber": { "type": "string" },
        "meetingDate": { "type": "string" },
        "potentialTier": { "type": "string" },
        "leadCategory": { "type": "string" },
        "nextActionItem": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["name", "email", "status", "salesRepId"]
    },
    "SystemLog": {
      "title": "System Log",
      "description": "Records of administrative and system actions",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "action", "details", "timestamp"]
    }
  },
  "firestore": {
    "/config/site": {
      "schema": "SiteConfig",
      "description": "Global site content and configuration"
    },
    "/enquiries/{enquiryId}": {
      "schema": "Enquiry",
      "description": "User form submissions"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Role-based user records"
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Sales lead records for tracking"
    },
    "/logs/{logId}": {
      "schema": "SystemLog",
      "description": "Audit logs for system actions"
    }
  }
}
