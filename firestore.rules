rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && request.auth.token.email == 'piyush.resoluteai@gmail.com';
    }
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isLead() {
      return isSignedIn() && getUserData().role == 'lead';
    }

    match /config/site {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /enquiries/{enquiryId} {
      allow create: if isValidEnquiry(request.resource.data);
      allow read, list, delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isLead());
      allow list: if isSignedIn() && (isAdmin() || isLead());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /leads/{leadId} {
      allow create: if isSignedIn();
      allow list, get: if isSignedIn() && (
        resource.data.salesRepId == request.auth.uid || 
        isAdmin() || 
        (isLead() && resource.data.team == getUserData().team)
      );
      allow update: if isSignedIn() && (
        resource.data.salesRepId == request.auth.uid || 
        isAdmin() || 
        (isLead() && resource.data.team == getUserData().team)
      );
    }

    match /logs/{logId} {
      allow create: if isSignedIn();
      allow read, list: if isAdmin();
    }

    function isValidEnquiry(data) {
      return data.keys().hasAll(['name', 'email', 'plan', 'message', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.email is string && data.email.matches('^[^@]+@[^@]+\\.[^@]+$') &&
             data.plan is string && data.plan.size() > 0 &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 3000 &&
             data.createdAt == request.time;
    }
  }
}
